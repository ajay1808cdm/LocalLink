{
  "name": "locallink-backend",
  "version": "1.0.0",
  "description": "LocalLink Node.js + Express + PostgreSQL Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "lint:security": "eslint . --ext .js",
    "test:load": "artillery run loadtest.yml --output reports/loadtest-report.json",
    "test:load-report": "artillery report reports/loadtest-report.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "artillery": "^2.0.33",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^2.1.1",
    "nodemon": "^3.1.4"
  }
}
